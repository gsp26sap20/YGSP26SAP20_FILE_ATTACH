projection;
strict ( 2 );

define behavior for Z_C_ATTACH
{
  use create;
  use update;
  use delete;

  use association _Versions { create; }
  use association _Audit;
  use association _Links;
  use action Reactivate;


}
define behavior for Z_C_ATTACH_VER
{
  use create;
  use update;
  use delete;

  use association _Attachment;
}

define behavior for Z_C_ATT_AUDIT
{
  use association _Attachment;
}